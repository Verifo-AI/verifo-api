{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "platform-nodes-worker": "export NODE_ENV=development && pnpm run build && node --enable-source-maps ./dist/platformNodesWorker.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node ./test.mjs"
  },
  "dependencies": {
    "@clerk/express": "^2.1.32",
    "@clerk/shared": "^4.22.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "@workspace/verifo-node-client": "workspace:*",
    "bs58": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/bs58": "^5.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}
